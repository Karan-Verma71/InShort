    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const {\n  title,\n  author_name,\n  video_url,\n  summary,\n  explanation,\n  key_learnings,\n  important_concepts,\n  applications\n} = $json;\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\nbody{\n    font-family: Arial, sans-serif;\n    margin:40px;\n    line-height:1.6;\n}\n\nh1{\n    color:#2c3e50;\n    border-bottom:2px solid #2c3e50;\n    padding-bottom:8px;\n}\n\nh2{\n    color:#34495e;\n    margin-top:30px;\n}\n\na{\n    color:#0066cc;\n}\n\nul{\n    margin-left:20px;\n}\n\n.info{\n    background:#f5f5f5;\n    padding:15px;\n    border-radius:8px;\n}\n</style>\n</head>\n\n<body>\n\n<h1>${title}</h1>\n\n<div class=\"info\">\n\n<p><strong>Channel:</strong> ${author_name}</p>\n\n<p><strong>Video:</strong>\n<a href=\"${video_url}\">\n${video_url}\n</a>\n</p>\n\n</div>\n\n<h2>Summary</h2>\n\n<p>${summary}</p>\n\n<h2>Detailed Explanation</h2>\n\n<p>${explanation.replace(/\\n/g,\"<br>\")}</p>\n\n<h2>Key Learnings</h2>\n\n<ul>\n${key_learnings.map(x=>`<li>${x}</li>`).join(\"\")}\n</ul>\n\n<h2>Important Concepts</h2>\n\n<ul>\n${important_concepts.map(x=>`<li>${x}</li>`).join(\"\")}\n</ul>\n\n<h2>Applications</h2>\n\n<ul>\n${applications.map(x=>`<li>${x}</li>`).join(\"\")}\n</ul>\n\n</body>\n</html>\n`;\n\nreturn {\n    json:{\n        html,\n        title\n    }\n};"
      },
